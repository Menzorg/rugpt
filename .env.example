# RuGPT Engine Configuration

# API Settings
API_HOST=127.0.0.1
API_PORT=8100
DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rugpt
DB_USER=postgres
DB_PASSWORD=

VECTOR_PORT=7432

# Alternative: Full DSN
# POSTGRES_DSN=postgresql://postgres@localhost/rugpt

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# LLM Settings
LLM_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen2.5:7b

# OpenAI Fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# File Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./uploads
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_TYPES=pdf,docx

# Scheduler
SCHEDULER_POLL_INTERVAL=30
SCHEDULER_ENABLED=true

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# SMTP Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# RAG / Embeddings
EMBEDDING_MODEL=qwen3-embedding:0.6b
RAG_SUMMARY_MODEL=qwen2.5:7b
RAG_TIKA_SERVER_ENDPOINT=http://localhost:9998
# RAG_STORE_DSN=postgresql://postgres@localhost/rugpt
RAG_VECTOR_DIM=768
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_SUMMARY_INPUT_MAX_CHARS=8000
